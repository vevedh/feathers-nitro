{
  "name": "feathers-api",
  "version": "0.0.0",
  "private": true,
  "description": "Feathers api for Nuxt integration demo",
  "contributors": [],
  "homepage": "",
  "bugs": {},
  "keywords": [
    "feathers"
  ],
  "main": "lib/client",
  "files": [
    "lib/**/*.d.ts",
    "lib/**/*.shared.js",
    "lib/client.js"
  ],
  "engines": {
    "node": "^22.12.0 || ^24.11.0 || >=26.0.0"
  },
  "feathers": {
    "language": "ts",
    "packager": "pnpm",
    "framework": "express",
    "transports": [
      "rest",
      "websockets"
    ],
    "schema": "typebox"
  },
  "directories": {
    "lib": "src",
    "test": "test"
  },
  "scripts": {
    "dev": "nodemon -x ts-node src/index.ts",
    "compile": "shx rm -rf lib/ && tsc",
    "start": "node lib/",
    "prettier": "npx prettier \"**/*.ts\" --write",
    "mocha": "cross-env NODE_ENV=test mocha test/ --require ts-node/register --recursive --extension .ts --exit",
    "test": "pnpm run mocha",
    "bundle:client": "pnpm run compile && pnpm pack --pack-destination ./public",
    "test:types": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@feathersjs/authentication": "catalog:",
    "@feathersjs/authentication-client": "catalog:",
    "@feathersjs/authentication-local": "catalog:",
    "@feathersjs/configuration": "catalog:",
    "@feathersjs/errors": "catalog:",
    "@feathersjs/express": "catalog:",
    "@feathersjs/feathers": "catalog:",
    "@feathersjs/koa": "catalog:",
    "@feathersjs/memory": "catalog:",
    "@feathersjs/schema": "catalog:",
    "@feathersjs/socketio": "catalog:",
    "@feathersjs/transport-commons": "catalog:",
    "@feathersjs/typebox": "catalog:",
    "compression": "catalog:",
    "winston": "catalog:"
  },
  "devDependencies": {
    "@feathersjs/adapter-commons": "catalog:",
    "@feathersjs/cli": "catalog:",
    "@feathersjs/rest-client": "catalog:",
    "@gabortorma/antfu-eslint-config": "catalog:",
    "@types/mocha": "catalog:",
    "@types/node": "catalog:",
    "axios": "catalog:",
    "cross-env": "catalog:",
    "mocha": "catalog:",
    "nodemon": "catalog:",
    "prettier": "catalog:",
    "shx": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:"
  }
}
