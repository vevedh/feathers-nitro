{
  "name": "@vevedh/feathers-nitro",
  "type": "module",
  "version": "0.4.4",
  "packageManager": "pnpm@9.15.9",
  "description": "FeathersJS integration for Nuxt/Nitro with Express, Koa, Socket.IO, and multi-instance support",
  "author": "vevedh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vevedh/feathers-nitro.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nuxt",
    "nitro",
    "nitro-plugin",
    "feathers",
    "feathersjs",
    "express",
    "expressjs",
    "koa",
    "koajs",
    "socket.io"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./routers": {
      "types": "./dist/runtime/routers/index.d.ts",
      "import": "./dist/runtime/routers/index.mjs",
      "require": "./dist/runtime/routers/index.cjs"
    },
    "./plugins": {
      "types": "./dist/runtime/plugins/index.d.ts",
      "import": "./dist/runtime/plugins/index.mjs",
      "require": "./dist/runtime/plugins/index.cjs"
    },
    "./handlers": {
      "types": "./dist/runtime/handlers/index.d.ts",
      "import": "./dist/runtime/handlers/index.mjs",
      "require": "./dist/runtime/handlers/index.cjs"
    },
    "./setup": {
      "types": "./dist/runtime/setup.d.ts",
      "import": "./dist/runtime/setup.mjs",
      "require": "./dist/runtime/setup.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "unbuild",
    "dev:nuxt": "pnpm --filter nuxt-app dev",
    "dev:api": "pnpm --filter feathers-api dev",
    "prerelease": "pnpm check:identity && pnpm check:portability && pnpm test:types && pnpm lint && pnpm test:all",
    "release": "release-it",
    "lint": "pnpm lint:root && pnpm lint:workspaces",
    "lint:fix": "pnpm lint:root:fix && pnpm lint:workspaces:fix",
    "test": "node scripts/run-vitest-suite.mjs",
    "test:all": "pnpm --dir playground/feathers-api test && pnpm test",
    "test:watch": "vitest watch test/*",
    "test:types": "vue-tsc --noEmit && pnpm --dir playground/feathers-api exec tsc --noEmit && pnpm --dir playground/nuxt-app exec vue-tsc --noEmit",
    "cleanup": "nuxi cleanup",
    "prepare": "nuxi prepare && nitro prepare",
    "release:dry-run": "release-it --dry-run",
    "check:identity": "node scripts/check-package-identity.mjs",
    "deps:check": "taze",
    "deps:check:recursive": "taze -r",
    "deps:update:safe": "taze minor -w --maturity-period 14",
    "deps:update:safe:recursive": "taze minor -r -w --maturity-period 14",
    "deps:update:major:review": "taze major -r",
    "verify": "pnpm check:identity && pnpm check:portability && pnpm check:test-runner && pnpm test:types && pnpm lint && pnpm test:all && pnpm pack:check",
    "lint:workspaces": "pnpm --dir playground/feathers-api exec eslint . && pnpm --dir playground/nuxt-app prepare && pnpm --dir playground/nuxt-app exec eslint .",
    "lint:workspaces:fix": "pnpm --dir playground/feathers-api exec eslint . --fix && pnpm --dir playground/nuxt-app prepare && pnpm --dir playground/nuxt-app exec eslint . --fix",
    "pack:check": "pnpm pack --pack-destination .pack-check",
    "check:portability": "node scripts/check-lockfile-portability.mjs",
    "lint:root": "eslint --config eslint.config.mjs eslint.config.mjs taze.config.js scripts src test",
    "lint:root:fix": "eslint --config eslint.config.mjs eslint.config.mjs taze.config.js scripts src test --fix",
    "check:test-runner": "node scripts/check-vitest-retry.mjs"
  },
  "dependencies": {
    "@feathersjs/errors": "^5.0.45",
    "@feathersjs/express": "^5.0.45",
    "@feathersjs/feathers": "^5.0.45",
    "@feathersjs/koa": "^5.0.45",
    "@feathersjs/socketio": "^5.0.45",
    "engine.io": "^6.6.9",
    "express": "^4.22.2",
    "h3": "1.12.0",
    "nitropack": "2.9.7"
  },
  "devDependencies": {
    "@gabortorma/antfu-eslint-config": "^2.4.2",
    "@gabortorma/nuxt-eslint-layer": "^0.2.6",
    "@nuxt/devtools": "^1.7.0",
    "@nuxt/schema": "^3.21.8",
    "@nuxt/test-utils": "^3.23.0",
    "@types/koa": "^2.15.2",
    "@types/node": "^22.19.21",
    "eslint": "^9.17.0",
    "nuxi": "^3.35.2",
    "nuxt": "^3.21.8",
    "release-it": "^17.11.0",
    "taze": "^19.14.1",
    "typescript": "^5.9.3",
    "unbuild": "^2.0.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.12"
  },
  "pnpm": {
    "updateConfig": {
      "ignoreDependencies": [
        "h3",
        "nitropack"
      ]
    }
  },
  "contributors": [
    "Gabor Torma (original author)"
  ],
  "homepage": "https://github.com/vevedh/feathers-nitro#readme",
  "bugs": {
    "url": "https://github.com/vevedh/feathers-nitro/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
